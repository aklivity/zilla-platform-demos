FROM bitnamilegacy/kafka:3.5
USER root
RUN install_packages gettext

ADD ./mm2.template /opt/mirrormaker/mm2.template
ADD ./run.sh /opt/mirrormaker/run.sh
RUN chmod +x /opt/mirrormaker/run.sh

RUN mkdir -p /var/run/mirrormaker
RUN chown 1234 /var/run/mirrormaker

ENV KAFKA_CFG_PROCESS_ROLES=broker,controller
ENV KAFKA_CFG_NODE_ID=1
ENV KAFKA_CFG_LISTENERS=CLIENT://:9092,INTERNAL://:29092,CONTROLLER://:9093
ENV KAFKA_CFG_LISTENER_SECURITY_PROTOCOL_MAP=CLIENT:PLAINTEXT,INTERNAL:PLAINTEXT,CONTROLLER:PLAINTEXT
ENV KAFKA_CFG_CONTROLLER_QUORUM_VOTERS=1@127.0.0.1:9093
ENV KAFKA_CFG_CONTROLLER_LISTENER_NAMES=CONTROLLER
ENV KAFKA_CFG_INTER_BROKER_LISTENER_NAME=INTERNAL
ENV ALLOW_PLAINTEXT_LISTENER=yes
ENV KAFKA_JMX_PORT=0
ENV JMX_PORT=0

USER 1234
CMD /opt/mirrormaker/run.sh